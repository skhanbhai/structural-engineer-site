# Files that must NEVER ship to the public asset bucket.
# Without this, Wrangler was uploading the entire .git/ directory,
# which exposed the repo's git history at /.git/HEAD etc.
.git
.git/**
.wrangler
.wrangler/**
.gitignore
.assetsignore
wrangler.jsonc
src
src/**
node_modules
node_modules/**
*.log
.DS_Store
# Internal working docs — never public
docs
docs/**
# Unused draft asset with fabricated job details — must not be served
assets/services/panoptic-beam-calculation-example.svg
